generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserPlan {
  free
  pro
  enterprise
}

enum AgentStatus {
  draft
  deploying
  published
  stopped
  failed
}

enum ChannelType {
  telegram
  whatsapp
  discord
  widget
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(user)
  plan          UserPlan  @default(free)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  agents        Agent[]
  usageLogs     UsageLog[]
  @@index([email])
  @@index([role])
}

model Agent {
  id                 String              @id @default(cuid())
  userId             String
  name               String
  description        String              @default("")
  avatar             String?
  systemPrompt       String              @default("")
  model              String              @default("deepseek-ai/deepseek-v4-flash")
  temperature        Float               @default(0.7)
  tools              Json                @default("[]")
  byokProvider       String?
  byokApiKey         String?
  status             AgentStatus         @default(draft)
  version            Int                 @default(1)
  containerId        String?
  sandboxUrl         String?
  sandboxSecret      String?
  publishedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  knowledgeBases     KnowledgeBase[]
  telegramConnection TelegramConnection?
  channels           Channel[]
  deployJobs         DeployJob[]
  usageLogs          UsageLog[]
  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model Conversation {
  id        String   @id @default(cuid())
  agentId   String
  userId    String
  title     String   @default("New Chat")
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@index([agentId])
  @@index([userId])
  @@index([createdAt])
}

model KnowledgeBase {
  id              String   @id @default(cuid())
  agentId         String
  fileName        String
  fileType        String
  content         String
  vectorNamespace String?
  createdAt       DateTime @default(now())
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@index([agentId])
}

model TelegramConnection {
  id           String   @id @default(cuid())
  agentId      String   @unique
  botToken     String
  botUsername  String?
  botName      String?
  webhookUrl   String?
  isActive     Boolean  @default(false)
  allowedUsers Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// Unified multi-channel tracking (Telegram, WhatsApp, Discord, Widget)
model Channel {
  id        String      @id @default(cuid())
  agentId   String
  type      ChannelType
  config    Json        @default("{}")
  isActive  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  agent     Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@unique([agentId, type])
  @@index([agentId])
  @@index([type])
}

model DeployJob {
  id        String   @id @default(cuid())
  agentId   String
  status    String   @default("queued")
  logs      String   @default("")
  version   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@index([agentId])
  @@index([createdAt])
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  agentId   String?
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  cost      Float    @default(0)
  model     String?
  channel   String?  // 'web' | 'telegram' | 'whatsapp' | 'discord' | 'widget'
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([agentId])
  @@index([createdAt])
  @@index([userId, createdAt])
}
