# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agentforge:agentforge_password@localhost:5433/agentforge

# ── Auth (REQUIRED — generate with: openssl rand -hex 32) ────────────────────
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── App URL (used for channel webhooks) ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── LLM API Keys (at least one required) ─────────────────────────────────────
GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
OPENAI_API_KEY=

# ── Web Search Tools (optional — enables web_search tool for agents) ──────────
SERPAPI_KEY=          # https://serpapi.com
BRAVE_SEARCH_KEY=     # https://api.search.brave.com (alternative)

# ── Sandbox (defaults work for most VPS setups) ───────────────────────────────
SANDBOX_IMAGE=agentforge-sandbox:latest
SANDBOX_NETWORK=agentforge-sandbox-net
SANDBOX_WORKSPACE_ROOT=/var/agentforge/workspaces
