# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agentforge:agentforge_password@localhost:5433/agentforge

# ── Auth (REQUIRED — generate with: openssl rand -hex 32) ────────────────────
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── App URL (used for channel webhooks) ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── PostgreSQL Password (used by docker-compose) ─────────────────────────────
POSTGRES_PASSWORD=agentforge_password

# ── LLM API Keys (at least one required) ─────────────────────────────────────
GROQ_API_KEY=          # https://console.groq.com (free tier available)
NVIDIA_NIM_API_KEY=    # https://build.nvidia.com
OPENAI_API_KEY=        # https://platform.openai.com
ANTHROPIC_API_KEY=     # https://console.anthropic.com

# ── Web Search Tools (optional — enables web_search tool for agents) ──────────
SERPAPI_KEY=          # https://serpapi.com
BRAVE_SEARCH_KEY=     # https://api.search.brave.com (alternative)

# ── Sandbox (defaults work for most VPS setups) ───────────────────────────────
SANDBOX_IMAGE=agentforge-sandbox:latest
SANDBOX_NETWORK=agentforge-sandbox-net
SANDBOX_WORKSPACE_ROOT=/var/agentforge/workspaces

# ── Telegram Webhook Security (optional but recommended) ──────────────────────
# Set this to a random string and configure in your Telegram bot settings
# to validate incoming webhook requests
TELEGRAM_WEBHOOK_SECRET=

# ── Demo Mode (optional — enables the "Try Demo" button on landing page) ──────
# Only set these if you want a public demo account
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
